# NanoForge Backend — Environment Configuration
# Copy to .env and fill in values

# App
NANOFORGE_ENV=dev
NANOFORGE_APP_NAME=NanoForge Backend

# Arc Testnet
NANOFORGE_ARC_CHAIN_ID=5042002
NANOFORGE_ARC_RPC_URL=https://rpc.arc.network
NANOFORGE_ARC_USDC_ADDRESS=0x79AEc4EeA31D50792F61D1Ca0733C18c89524C9e

# Circle Wallets (Developer-Controlled) — PRIMARY wallet solution
# Get these from https://console.circle.com
NANOFORGE_CIRCLE_API_KEY=
NANOFORGE_CIRCLE_WALLET_SET_ID=
NANOFORGE_CIRCLE_ENTITY_SECRET=
NANOFORGE_CIRCLE_ENTITY_SECRET_CIPHERTEXT=

# Deployed Contracts (fill after: forge script DeployArcTestnet)
NANOFORGE_CONTRACT_NFG_TOKEN=
NANOFORGE_CONTRACT_AGENT_NFT=
NANOFORGE_CONTRACT_YIELD_VAULT=
NANOFORGE_CONTRACT_JOB_SETTLER=
NANOFORGE_CONTRACT_JOB_LEDGER=
NANOFORGE_CONTRACT_JOB_PAYMENT_ROUTER=
NANOFORGE_CONTRACT_AGENT_MARKET=

# Signing Keys (never commit real keys)
NANOFORGE_BROADCASTER_PRIVATE_KEY=
NANOFORGE_ADAPTER_PRIVATE_KEY=
NANOFORGE_AGENT_OWNER_PRIVATE_KEY=
NANOFORGE_BUYER_PRIVATE_KEY=
NANOFORGE_PLATFORM_TREASURY_PRIVATE_KEY=

# AgentSkillOS Execution
NANOFORGE_AGENTSKILLOS_ROOT=../agentskillos
NANOFORGE_AGENTSKILLOS_PYTHON_EXECUTABLE=python3
NANOFORGE_AGENTSKILLOS_LLM_MODEL=gemini-2.5-flash

# Gemini (Google prize track)
NANOFORGE_GEMINI_API_KEY=
NANOFORGE_GEMINI_MODEL=gemini-2.5-flash
NANOFORGE_GEMINI_PRO_MODEL=gemini-2.5-pro
